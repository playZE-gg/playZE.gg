---
import { Image } from 'astro:assets';

const { data } = Astro.locals.starlightRoute.entry;
const hero = data.hero as any;
if (!hero) return;

const title: string = hero.title ?? data.title;
const tagline: string | undefined = hero.tagline;
const actions: Array<{ text: string; link: string; variant: string }> = hero.actions ?? [];

// image.file is ImageMetadata when Astro processes a local asset
const imageFile = hero.image?.file as import('astro').ImageMetadata | undefined;
---

<div class="hero-wrapper">
  <div class="hero-noise" aria-hidden="true"></div>
  <div class="hero-content">
    {imageFile && (
      <Image
        src={imageFile}
        alt={hero.image?.alt ?? ''}
        class="hero-logo"
        width={120}
        height={120}
        loading="eager"
        fetchpriority="high"
      />
    )}
    <h1 class="hero-title">{title}</h1>
    {tagline && <p class="hero-tagline">{tagline}</p>}
    {actions.length > 0 && (
      <div class="hero-actions">
        {actions.map((action) => (
          <a
            href={action.link}
            class:list={['hero-cta', action.variant === 'primary' ? 'cta-primary' : 'cta-secondary']}
          >
            {action.text}
          </a>
        ))}
      </div>
    )}
  </div>
  <div class="hero-divider" aria-hidden="true"></div>
</div>

<style>
  .hero-wrapper {
    position: relative;
    text-align: center;
    padding: 4rem 2rem 3rem;
    background: var(--sl-color-bg);
    overflow: hidden;
  }

  /* Subtle diagonal stripe texture */
  .hero-noise {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 4px,
      rgba(255, 255, 255, 0.015) 4px,
      rgba(255, 255, 255, 0.015) 5px
    );
    pointer-events: none;
  }
  :global(:root[data-theme='light']) .hero-noise {
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 4px,
      rgba(0, 0, 0, 0.025) 4px,
      rgba(0, 0, 0, 0.025) 5px
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 52rem;
    margin: 0 auto;
  }

  .hero-logo {
    width: 7rem;
    height: auto;
  }

  .hero-title {
    font-family: var(--sl-font-mono);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--sl-color-white);
    margin: 0;
    line-height: 1.1;
  }

  .hero-tagline {
    font-size: clamp(1rem, 3vw, 1.15rem);
    color: var(--sl-color-gray-3);
    max-width: 44ch;
    line-height: 1.6;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.4rem;
    border-radius: 4px;
    font-family: var(--sl-font-mono);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: filter 150ms ease;
  }
  .hero-cta:hover {
    filter: brightness(1.1);
  }

  .cta-primary {
    background: var(--sl-color-accent);
    color: #0f1117;
  }

  .cta-secondary {
    background: transparent;
    border: 1px solid var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .hero-divider {
    margin-top: 3rem;
    height: 1px;
    background: var(--sl-color-hairline);
  }
</style>
